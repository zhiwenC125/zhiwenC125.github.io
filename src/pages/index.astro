---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE, AUTHOR } from '../consts';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
).slice(0, 3);
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<img class="avatar" src={AUTHOR.avatar} alt={AUTHOR.name} />
				<h1>{AUTHOR.name}</h1>
				<p class="bio">{AUTHOR.bio}</p>
				{AUTHOR.location && <p class="location">{AUTHOR.location}</p>}
			</section>

			<section class="section">
				<h2>Recent Posts</h2>
				<ul class="post-list">
					{posts.map((post) => (
						<li>
							<a href={`/blog/${post.id}/`}>
								<span class="post-title">{post.data.title}</span>
								<span class="post-date">
									{post.data.pubDate.toLocaleDateString('zh-CN', {
										year: 'numeric',
										month: 'long',
										day: 'numeric',
									})}
								</span>
							</a>
						</li>
					))}
				</ul>
				<a href="/blog" class="view-all">View all &rarr;</a>
			</section>

			<section class="section">
				<h2>Projects</h2>
				<div class="project-cards">
					<a href="/RTOS_sim/" class="project-card">
						<h3>RTOS Visualizer</h3>
						<p>Interactive RTOS simulator — task scheduling, semaphores, mutexes, message queues, heap management.</p>
						<div class="tags">
							<span class="tag">RTOS</span>
							<span class="tag">Interactive</span>
							<span class="tag">Education</span>
						</div>
					</a>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		max-width: 680px;
		margin: 0 auto;
		padding: 2em 1em 3em;
	}

	/* Hero */
	.hero {
		text-align: center;
		padding: 2.5em 0 1.5em;
	}
	.avatar {
		width: 100px;
		height: 100px;
		border-radius: 50%;
		object-fit: cover;
		border: 2px solid var(--border, #dee2e6);
		box-shadow: 0 2px 8px rgba(0,0,0,0.06);
	}
	.hero h1 {
		margin: 0.6em 0 0.2em;
		font-size: 1.8em;
	}
	/* 去掉 hero h1 后面的伪元素线 */
	.hero h1::after { display: none; }
	.bio {
		color: rgb(var(--gray));
		font-size: 1.05em;
		margin: 0;
		font-style: italic;
	}
	.location {
		color: rgb(var(--gray));
		font-size: 0.85em;
		margin-top: 0.3em;
	}

	/* Sections */
	.section {
		margin: 2.5em 0;
	}
	.section h2 {
		font-size: 1.2em;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		color: rgb(var(--gray));
		font-weight: 600;
	}

	/* Post list */
	.post-list {
		list-style: none;
		padding: 0;
		margin: 0.8em 0;
	}
	.post-list li a {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		padding: 0.7em 0;
		border-bottom: 1px solid rgba(var(--gray-light), 0.7);
		color: rgb(var(--black));
		transition: color 0.2s;
	}
	.post-list li a:hover {
		color: rgb(var(--accent));
		border-bottom-color: rgb(var(--accent));
	}
	.post-title {
		font-weight: 500;
	}
	.post-date {
		color: rgb(var(--gray));
		font-size: 0.82em;
		white-space: nowrap;
		margin-left: 1.5em;
		font-variant-numeric: tabular-nums;
	}
	.view-all {
		display: inline-block;
		margin-top: 0.6em;
		font-size: 0.9em;
		font-weight: 500;
	}

	/* Project cards */
	.project-cards {
		display: grid;
		grid-template-columns: 1fr;
		gap: 1em;
		margin-top: 0.8em;
	}
	.project-card {
		border: 1px solid var(--border, #dee2e6);
		border-radius: 6px;
		padding: 1.2em 1.4em;
		color: rgb(var(--black));
		background: white;
		transition: box-shadow 0.2s, border-color 0.2s;
	}
	.project-card:hover {
		box-shadow: var(--box-shadow);
		border-color: rgb(var(--accent));
	}
	.project-card h3 {
		margin: 0 0 0.4em;
		font-size: 1.05em;
	}
	.project-card h3::after { display: none; }
	.project-card p {
		margin: 0 0 0.8em;
		color: rgb(var(--gray));
		font-size: 0.9em;
		line-height: 1.6;
	}
	.tags {
		display: flex;
		gap: 0.4em;
		flex-wrap: wrap;
	}
	.tag {
		background: rgba(var(--accent), 0.08);
		color: rgb(var(--accent));
		padding: 0.15em 0.55em;
		border-radius: 3px;
		font-size: 0.78em;
		font-weight: 500;
		letter-spacing: 0.02em;
	}
</style>
