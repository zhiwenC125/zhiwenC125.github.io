---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`Projects - ${SITE_TITLE}`} description="Interactive projects" />
	</head>
	<body>
		<Header />
		<main>
			<h1>Projects</h1>
			<div class="project-list">
				<a href="/RTOS_sim/" class="project-card">
					<h2>RTOS Visualizer</h2>
					<p>Web-based RTOS simulator with interactive demos: priority-based preemptive scheduling, round-robin, mutex with priority inheritance, binary/counting semaphores, message queues, and heap memory management.</p>
					<div class="tags">
						<span class="tag">RTOS</span>
						<span class="tag">JavaScript</span>
						<span class="tag">Interactive</span>
						<span class="tag">Education</span>
					</div>
				</a>
			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		max-width: 680px;
	}
	h1 {
		font-size: 1.8em;
		margin-bottom: 1em;
	}
	.project-list {
		display: flex;
		flex-direction: column;
		gap: 1em;
	}
	.project-card {
		border: 1px solid var(--border, #dee2e6);
		border-radius: 6px;
		padding: 1.4em 1.6em;
		color: rgb(var(--black));
		background: white;
		transition: box-shadow 0.2s, border-color 0.2s;
	}
	.project-card:hover {
		box-shadow: var(--box-shadow);
		border-color: rgb(var(--accent));
	}
	.project-card h2 {
		margin: 0 0 0.5em;
		font-size: 1.2em;
	}
	.project-card h2::after { display: none; }
	.project-card p {
		margin: 0 0 1em;
		color: rgb(var(--gray));
		font-size: 0.92em;
		line-height: 1.7;
	}
	.tags {
		display: flex;
		gap: 0.4em;
		flex-wrap: wrap;
	}
	.tag {
		background: rgba(var(--accent), 0.08);
		color: rgb(var(--accent));
		padding: 0.15em 0.55em;
		border-radius: 3px;
		font-size: 0.78em;
		font-weight: 500;
	}
</style>
